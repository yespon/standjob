# ── LLM 配置 ──────────────────────────────────────────────
# 支持 DeepSeek / OpenAI / Anthropic 兼容接口
# 系统按优先级检测：OPENAI_API_KEY → DEEPSEEK_API_KEY → ANTHROPIC_API_KEY
OPENAI_BASE_URL=https://llmproxy.ruijie.com.cn/v1
OPENAI_API_KEY=sk-pkrXq9qlB1on_TLUhwr8xg

# ── 可选：覆盖参考文档 ────────────────────────────────────
# 不设置时，系统自动使用 backend/references/ 下的内嵌文档
# SCORING_CRITERIA_PATH=/path/to/评分标准.xlsx
# TEACHING_MATERIAL_PATH=/path/to/教材.pdf

# ── 可选：禁用 LLM ───────────────────────────────────────
# 设为 1 时使用纯规则兜底模式（无需 API Key 即可运行）
# STANDJOB_DISABLE_LLM=1
